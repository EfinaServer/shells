{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "automerge": true,
  "rebaseWhen": "conflicted",
  "platformAutomerge": true,
  "ignorePaths": [
    "java/lazymc/source/Dockerfile"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^java/lazymc/\\d+/Dockerfile$"],
      "matchStrings": [
        "ARG LAZYMC_VERSION=(?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "EfinaServer/lazymc",
      "datasourceTemplate": "github-releases",
      "extractVersion": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ]
}
