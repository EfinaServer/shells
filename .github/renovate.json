{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "automerge": true,
  "rebaseWhen": "conflicted",
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^java/lazymc/\\d+/Dockerfile$"],
      "matchStrings": ["ARG LAZYMC_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "EfinaServer/lazymc",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
